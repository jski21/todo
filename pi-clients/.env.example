# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Device identity — path to a file containing the long-lived refresh token
# obtained from the web app (see README.md "Pairing the device").
# Must be writable by the service user; the SDK rotates the token on every refresh.
DEVICE_REFRESH_TOKEN_PATH=/var/lib/donelist/refresh_token

# --- Printer ---------------------------------------------------------
# dummy | usb | serial | file
PRINTER_BACKEND=dummy
# For "usb": hex ids from `lsusb` (e.g. 0x04b8 / 0x0e15).
# PRINTER_USB_VENDOR=0x04b8
# PRINTER_USB_PRODUCT=0x0e15
# For "serial":
# PRINTER_SERIAL_PATH=/dev/serial0
# For "dummy"/"file": where to dump rendered bytes for inspection.
PRINTER_DUMMY_FILE=/tmp/donelist-printer.out
# 32 for 58mm rolls, 48 for 80mm rolls.
PRINTER_WIDTH_CHARS=32
PRINTER_POLL_INTERVAL_S=3
PRINTER_MAX_ATTEMPTS=5

# --- Scanner ---------------------------------------------------------
# evdev (real scanner) | stdin (testing)
SCANNER_BACKEND=stdin
# SCANNER_DEVICE_PATH=/dev/donelist-scanner    # set by udev rule
SCANNER_GRAB_EXCLUSIVE=true

# --- Offline buffer + retry -----------------------------------------
BUFFER_DB_PATH=/var/lib/donelist/buffer.sqlite
NETWORK_RETRY_INTERVAL_S=10
